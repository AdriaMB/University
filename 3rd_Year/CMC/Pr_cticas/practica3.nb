Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ex1", "[", 
     RowBox[{
     "inicial_List", ",", " ", "regla_Integer", ",", " ", "t_Integer"}], 
     "]"}], ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "len", ",", "binarydigits", ",", " ", "estado", ",", "nuevoEstado", ",",
         " ", "i", ",", " ", "j", ",", " ", "state", ",", " ", "left", ",", 
        " ", "center", ",", " ", "right", ",", " ", "index", ",", " ", 
        "nextState", ",", " ", "listaFrames"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"len", "=", " ", 
        RowBox[{"Length", "[", "inicial", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Codificar", " ", "la", " ", "regla"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"binarydigits", " ", "=", " ", 
        RowBox[{"IntegerDigits", "[", 
         RowBox[{"regla", ",", " ", "2", ",", " ", "8"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"binarydigits", " ", "=", " ", 
        RowBox[{"Reverse", "[", "binarydigits", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"estado", "  ", "=", " ", "inicial"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"nuevoEstado", " ", "=", " ", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"listaFrames", " ", "=", " ", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"t", ":", " ", 
         RowBox[{"numero", " ", "de", " ", "conf", " ", "a", " ", 
          RowBox[{"calcular", ".", " ", "Iteramos"}]}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"For", "[", " ", 
        RowBox[{
         RowBox[{"i", " ", "=", " ", "0"}], ",", " ", 
         RowBox[{"i", " ", "<", " ", "t"}], ",", " ", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"Iteracion", " ", "t"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"j", " ", "=", " ", "0"}], ",", " ", 
            RowBox[{"j", " ", "<", " ", "len"}], ",", " ", 
            RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"left", " ", "=", " ", 
              RowBox[{
               RowBox[{"Mod", "[", 
                RowBox[{
                 RowBox[{"j", " ", "+", " ", "len", "-", "1"}], ",", " ", 
                 "len"}], "]"}], "  ", "+", " ", "1"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"center", " ", "=", " ", 
              RowBox[{"j", " ", "+", " ", "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"right", " ", "=", " ", 
              RowBox[{
               RowBox[{"Mod", "[", 
                RowBox[{
                 RowBox[{"j", " ", "+", " ", "1"}], ",", " ", "len"}], "]"}], 
               " ", "+", " ", "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"state", " ", "=", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"estado", "[", 
                 RowBox[{"[", "left", "]"}], "]"}], ",", " ", 
                RowBox[{"estado", "[", 
                 RowBox[{"[", "center", "]"}], "]"}], ",", " ", 
                RowBox[{"estado", "[", 
                 RowBox[{"[", "right", "]"}], "]"}]}], "}"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"index", "=", " ", 
              RowBox[{
               RowBox[{"FromDigits", "[", 
                RowBox[{"state", ",", " ", "2"}], "]"}], " ", "+", " ", 
               "1"}]}], ";", " ", 
             RowBox[{"(*", 
              RowBox[{
              "el", " ", "indice", " ", "esta", " ", "codificado", " ", "en", 
               " ", 
               RowBox[{"binario", ".", " ", "Debo"}], " ", "sumarle", " ", 
               "1", " ", "porque", " ", "para", " ", "acceder", " ", "a", " ",
                "una", " ", "posicion", " ", "de", " ", "una", " ", "lista", " ",
                "en", " ", 
               RowBox[{"Math", ".", " ", "se"}], " ", "comienza", " ", "por", 
               " ", "1"}], "*)"}], "\[IndentingNewLine]", 
             RowBox[{"nextState", " ", "=", "  ", 
              RowBox[{"binarydigits", "[", 
               RowBox[{"[", "index", "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"nuevoEstado", ",", " ", "nextState"}], "]"}], ";"}]}], 
           "\[IndentingNewLine]", "]"}], ";", 
          RowBox[{"(*", 
           RowBox[{"For", " ", "j"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"listaFrames", ",", " ", "nuevoEstado"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"estado", " ", "=", " ", "nuevoEstado"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"nuevoEstado", " ", "=", " ", 
           RowBox[{"{", "}"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
       RowBox[{"(*", 
        RowBox[{"For", " ", "i"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"Animacion", "[", 
        RowBox[{"listaFrames", ",", " ", "len"}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], 
  RowBox[{"(*", "Ex1", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Animacion", "[", 
     RowBox[{"listaFrames_List", ",", " ", "len_Integer"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"grid", ",", "anim", ",", " ", "frame", ",", "i"}], "}"}], ",",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"grid", " ", "=", " ", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", " ", "len"}], "]"}], ",", " ", "3"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"anim", "  ", "=", " ", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
         RowBox[{"i", " ", "<=", " ", 
          RowBox[{"Length", "[", "listaFrames", "]"}]}], ",", " ", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"grid", " ", ",", " ", 
            RowBox[{"listaFrames", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"grid", " ", "=", " ", 
           RowBox[{"Take", "[", 
            RowBox[{"grid", ",", " ", 
             RowBox[{"-", "3"}]}], "]"}]}], ";", " ", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"frame", " ", "0"}], ",", " ", 
            RowBox[{"frame", " ", "0"}], ",", " ", 
            RowBox[{"primer", " ", "frame"}]}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"frame", " ", "=", " ", 
           RowBox[{"ArrayPlot", "[", "grid", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"anim", ",", " ", "frame"}], "]"}], ";"}]}], 
        "\[IndentingNewLine]", "]"}], ";", 
       RowBox[{"(*", "for", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"ListAnimate", "[", "anim", "]"}]}]}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "]"}]}], ";"}], 
  RowBox[{"(*", "Animacion", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"regla", " ", "=", " ", "54"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"inicio", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1", ",", "1", ",", "1", ",", "0", ",", "0"}],
     "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t", " ", "=", " ", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Ex1", "[", 
  RowBox[{"inicio", ",", " ", "regla", ",", " ", "t"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
