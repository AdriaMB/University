             RowBox[{"j", " ", "=", " ", "1"}], ",", " ", 
             RowBox[{"j", " ", "<=", 
              RowBox[{"Length", "[", 
               RowBox[{"P", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", " ", 
             RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"Print", "[", 
               RowBox[{"P", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", " ", "2", ",", " ", "j"}], "]"}], "]"}], 
               "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"Print", "[", 
               RowBox[{"\"\<Intersection: \>\"", ",", " ", 
                RowBox[{"Intersection", "[", 
                 RowBox[{
                  RowBox[{"P", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "2", ",", " ", "j"}], "]"}], "]"}], ",",
                   " ", "N"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Intersection", "[", 
                  RowBox[{
                   RowBox[{"P", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "2", ",", " ", "j"}], "]"}], "]"}], ",",
                    " ", "auxSymbol"}], "]"}], " ", "!=", " ", 
                 RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
                "\[IndentingNewLine]", 
                RowBox[{"(*", " ", 
                 RowBox[{
                  RowBox[{
                  "The", " ", "intersection", " ", "between", " ", "the", " ",
                    "symbols", " ", "of", " ", "the", " ", "string", " ", 
                   "and", " ", "the", " ", "auxiliary", " ", "symbols", " ", 
                   "is", " ", "Empty"}], ",", " ", 
                  RowBox[{
                  "which", " ", "means", " ", "there", " ", "are", " ", "no", 
                   " ", "auxiliary", " ", "symbols"}], ",", " ", 
                  RowBox[{
                  "only", " ", "terminal", " ", "ones", " ", "or", " ", 
                   "lambda"}]}], "*)"}], "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"AppendTo", "[", 
                  RowBox[{"res", ",", " ", "auxSymbol"}], "]"}], ";"}]}], 
               "\[IndentingNewLine]", "\[IndentingNewLine]", 
               "\[IndentingNewLine]", "]"}], ";"}]}], 
            RowBox[{"(*", 
             RowBox[{"End", " ", "if"}], "*)"}], "\[IndentingNewLine]", "]"}],
            ";"}]}], 
         RowBox[{"(*", 
          RowBox[{"End", " ", "for"}], "*)"}], "\[IndentingNewLine]", "]"}], ";", 
        RowBox[{"(*", 
         RowBox[{"End", " ", "for"}], "*)"}], "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "res", "]"}], ";"}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Fin", " ", "Ex1"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Ex2", "[", 
      RowBox[{"Naux", ",", " ", "Taux", ",", " ", "Paux", ",", " ", "Saux"}], 
