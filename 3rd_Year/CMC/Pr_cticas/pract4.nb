Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ejercicio1", "[", "n_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sistema", ",", "tempMembrana", ",", "combinaciones", ",", 
        "combinacion", ",", "reglaID", ",", "out", ",", "i", ",", "randint", ",",
         " ", "newSistema"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"out", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sistema", " ", "=", 
        RowBox[{"{", 
         RowBox[{"1", ",", "a", ",", "a", ",", 
          RowBox[{"{", "2", "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", "n"}], ",", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"newSistema", "=", "sistema"}], ";", "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Obtenemos", " ", "todas", " ", "las", " ", "combinaciones", " ", 
            "de", " ", "reglas", " ", "posibles", " ", "y", " ", "aplicables",
             " ", "para", " ", "el", " ", "estado", " ", "actual", " ", 
            RowBox[{"(", 
             RowBox[{"para", " ", "la", " ", "membrana", " ", "1"}], ")"}]}], 
           " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"tempMembrana", "=", 
           RowBox[{"sistema", "[", 
            RowBox[{"[", 
             RowBox[{"2", ";;", 
              RowBox[{"-", "2"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"combinaciones", "=", 
           RowBox[{"Combinaciones", "[", 
            RowBox[{"tempMembrana", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", "a", "}"}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"a", ",", "a"}], "}"}]}], "}"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Elegimos", " ", "una", " ", "combinaci\[OAcute]n", " ", 
            "random"}], " ", "*)"}], "\[IndentingNewLine]", 
          RowBox[{"combinacion", "=", 
           RowBox[{"RandomChoice", "[", "combinaciones", "]"}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Print", "[", 
             
             RowBox[{"\"\<Combinaciones aplicables: \>\"", ",", 
              "combinaciones"}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             
             RowBox[{"\"\<Combinaci\[OAcute]n elegida: \>\"", ",", 
              "combinacion"}], "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{"\"\<Sistema antes: \>\"", ",", "newSistema"}], "]"}], 
            ";"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
          
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"j", "=", "1"}], ",", 
            RowBox[{"j", "<=", 
             RowBox[{"Length", "[", "combinacion", "]"}]}], ",", 
            RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"reglaID", "=", 
              RowBox[{"combinacion", "[", 
               RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Aplicamos", " ", "la", " ", "regla", " ", "i", " ", "de", " ", 
               "la", " ", "combinaci\[OAcute]n", " ", "elegida"}], " ", 
              "*)"}], "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"reglaID", "==", "1"}], ",", "\[IndentingNewLine]", 
               RowBox[{"(*", " ", 
                RowBox[{"Aplicamos", " ", "la", " ", "regla", " ", "1"}], " ",
                 "*)"}], "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"newSistema", "[", 
                  RowBox[{"[", 
                   RowBox[{"-", "1"}], "]"}], "]"}], "=", 
                 RowBox[{"Join", "[", 
                  RowBox[{
                   RowBox[{"newSistema", "[", 
                    RowBox[{"[", 
                    RowBox[{"-", "1"}], "]"}], "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"b", ",", "c", ",", "c"}], "}"}]}], "]"}]}], 
                ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
             "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"reglaID", "==", "2"}], ",", "\[IndentingNewLine]", 
               RowBox[{"(*", " ", 
                RowBox[{"Aplicamos", " ", "la", " ", "regla", " ", "2"}], " ",
                 "*)"}], "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{"newSistema", "=", 
                 RowBox[{"DeleteCases", "[", 
                  RowBox[{"newSistema", ",", "a", ",", 
                   RowBox[{"{", "1", "}"}], ",", "2"}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"out", ",", " ", "a"}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"AppendTo", "[", 
                 RowBox[{"out", ",", " ", "a"}], "]"}], ";"}]}], 
              "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", 
           "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"sistema", "=", "newSistema"}], ";"}]}], 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
