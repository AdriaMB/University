Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CombinacionesPrioritarias", "[", 
      RowBox[{"membrana_", ",", "reglasP_", ",", " ", "reglasNP_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "combinaciones", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"combinaciones", " ", "=", " ", 
         RowBox[{"Combinaciones", "[", 
          RowBox[{"membrana", ",", " ", "reglasP"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"combinaciones", " ", "==", " ", 
           RowBox[{"{", 
            RowBox[{"{", "}"}], "}"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"combinaciones", " ", "=", " ", 
            RowBox[{"Combinaciones", "[", 
             RowBox[{"membrana", ",", 
              RowBox[{"Join", "[", 
               RowBox[{"reglasP", ",", " ", "reglasNP"}], "]"}]}], "]"}]}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"Return", "[", "combinaciones", "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.988276772378656*^9, 3.9882768012620993`*^9}, {
  3.988277011638274*^9, 3.988277014318902*^9}, {3.9883460614423847`*^9, 
  3.988346203679144*^9}, {3.988346419353868*^9, 3.988346429253394*^9}, {
  3.9883466220766363`*^9, 3.988346647171555*^9}},
 CellLabel->"In[37]:=",ExpressionUUID->"34a0a491-e428-4780-8d28-d7a3be6ac37c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Ejercicio2", "[", 
     RowBox[{"n_", ",", "k_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sistema", ",", "membrana2", ",", "combM1", ",", " ", "combM2", ",", 
        " ", "tempMembrana1", ",", " ", "tempMembrana2", ",", " ", 
        "newSistema", ",", "combinacion", ",", " ", "i", ",", "j", ",", " ", 
        "reglaID", ",", " ", "aux"}], "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Construcci\[OAcute]n", " ", "del", " ", "sistema"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"sistema", " ", "=", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"Append", "[", 
             RowBox[{
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{"ConstantArray", "[", 
                 RowBox[{"a", ",", " ", "n"}], "]"}], ",", " ", 
                RowBox[{"ConstantArray", "[", 
                 RowBox[{"c", ",", " ", "k"}], "]"}]}], "]"}], ",", "d"}], 
             " ", "]"}]}], "]"}], ",", 
          RowBox[{"{", "3", "}"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<El sistema es \>\"", ",", " ", "sistema"}], "]"}], 
         ";"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"membrana2", " ", "=", " ", "True"}], ";", " ", 
       RowBox[{"(*", 
        RowBox[{"Tenemos", " ", "2", " ", "membranas", " ", "internas"}], 
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Combinaciones", " ", "de", " ", "reglas", " ", "posibles", " ", "en",
          " ", "la", " ", "membrana", " ", "1"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"tempMembrana1", "=", 
        RowBox[{"sistema", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", 
           RowBox[{"-", "3"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"combM1", "=", 
        RowBox[{"CombinacionesPrioritarias", "[", 
         RowBox[{"tempMembrana1", ",", 
          RowBox[{"{", 
           RowBox[{"{", 
            RowBox[{"c", ",", "d", ",", "e"}], "}"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"{", " ", "d", "}"}], "}"}]}], " ", "]"}]}], ";", " ", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<combM1:   \>\"", ",", " ", "combM1"}], "]"}], ";"}], 
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Combinaciones", " ", "de", " ", "reglas", " ", "posibles", " ", "en",
          " ", "la", " ", "membrana", " ", "2"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"tempMembrana2", "=", 
        RowBox[{
         RowBox[{"sistema", "[", 
          RowBox[{"[", 
           RowBox[{"-", "2"}], "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", 
           RowBox[{"-", "1"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"combM2", "=", 
        RowBox[{"CombinacionesPrioritarias", "[", 
         RowBox[{"tempMembrana2", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"a", ",", "c"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"a", ",", "e"}], "}"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"{", "d", "}"}], "}"}]}], " ", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<combM2:   \>\"", ",", " ", "combM2"}], "]"}], ";"}], 
        "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Mientras", " ", "que", " ", "hayan", " ", "reglas", " ", "que", " ",
           "podamos", " ", "aplicar"}], ",", " ", "continuamos"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"combM1", " ", "!=", " ", 
           RowBox[{"{", "}"}]}], " ", "||", " ", 
          RowBox[{"combM2", " ", "!=", 
           RowBox[{"{", "}"}]}]}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"newSistema", " ", "=", " ", "sistema"}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{"Modo", " ", "MAXIMAMENTE", " ", 
             RowBox[{"PARALELO", ":", " ", 
              RowBox[{
              "las", " ", "operaciones", " ", "deben", " ", "ejecutarse", " ",
                "en", " ", "paralelo"}]}]}], ",", " ", 
            RowBox[{
            "tanto", " ", "las", " ", "de", " ", "la", " ", "membrana", " ", 
             "1", " ", "como", " ", "las", " ", "de", " ", "la", " ", 
             "membrana", " ", "2"}]}], "*)"}], "\[IndentingNewLine]", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
            "Print", 
             "[", "\"\<MEMBRANA 1 ######################################\>\"",
              "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Aplicamos", " ", "las", " ", "reglas", " ", "de", " ", "la", " ", 
            "membrana", " ", "1"}], "*)"}], "\[IndentingNewLine]", 
          RowBox[{"(*", 
