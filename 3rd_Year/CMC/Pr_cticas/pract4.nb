Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ReglaAplicable", "[", 
     RowBox[{"membrana_", ",", "regla_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"elementosRequeridos", ",", " ", "SuficientesDeElemento"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Devuelve", " ", "True", " ", "si", " ", "la", " ", "regla", " ", 
         "se", " ", "puede", " ", "aplicar", " ", 
         RowBox[{"(", 
          RowBox[{
          "si", " ", "los", " ", "s\[IAcute]mbolos", " ", "requeridos", "\[IndentingNewLine]",
            "est\[AAcute]n", " ", "en", " ", "la", " ", "membrana"}], ")"}]}],
         ",", " ", 
        RowBox[{"False", " ", "otherwise"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "elementosRequeridos", " ", "es", " ", "una", " ", "lista", " ", 
        "donde", " ", "cada", " ", "elemento", " ", "de", " ", "regla", " ", 
        "aparece", " ", "solo", " ", "una", " ", "vez"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"elementosRequeridos", "=", 
        RowBox[{"DeleteDuplicates", "[", "regla", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Comprobamos", " ", "si"}], ",", " ", 
         RowBox[{"por", " ", "cada", " ", "elemento", " ", "requerido"}], ",",
          " ", 
         RowBox[{
          RowBox[{
          "el", " ", "n\[UAcute]mero", " ", "de", " ", "ocurrencias", " ", 
           "en", " ", "membrana", "\[IndentingNewLine]", "es"}], " ", ">=", 
          " ", 
          RowBox[{"al", " ", "de", " ", "regla", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"es", " ", "decir"}], ",", " ", 
             RowBox[{
             "si", " ", "hay", " ", "suficiente", " ", "de", " ", "cada", " ",
               "elemento", " ", "para", " ", "aplicar", " ", "la", " ", 
              "regla"}]}], ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"SuficientesDeElemento", "[", "x_", "]"}], ":=", 
        RowBox[{
         RowBox[{"Count", "[", 
          RowBox[{"membrana", ",", "x"}], "]"}], ">=", 
         RowBox[{"Count", "[", 
          RowBox[{"regla", ",", "x"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       
       RowBox[{"AllTrue", "[", 
        RowBox[{"elementosRequeridos", ",", "SuficientesDeElemento"}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AplicarRegla", "[", 
     RowBox[{"membrana_", ",", "regla_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"res", ",", "i", ",", "simbolo"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "=", "membrana"}], ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "regla", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
           "Por", " ", "cada", " ", "s\[IAcute]mbolo", " ", "de", " ", "la", " ",
             "regla"}], ",", " ", 
           RowBox[{
           "borramos", " ", "una", " ", "ocurrencia", " ", "en", " ", 
            "membrana"}]}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"simbolo", "=", 
           RowBox[{"regla", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"DeleteCases", "[", 
            RowBox[{"res", ",", "simbolo", ",", 
             RowBox[{"{", "1", "}"}], ",", "1"}], "]"}]}], ";"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Return", "[", "res", "]"}], ";"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CombinacionesRecursivo", "[", 
     RowBox[{"inicio_", ",", "membrana_", ",", "reglas_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"res", ",", "i", ",", "reglasAplicadas", ",", "newMembrana"}], 
       "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Devuelve", " ", "todas", " ", "las", " ", "combinaciones", " ", "de", 
        " ", "reglas", " ", "que", " ", "comienzan", " ", "por", " ", 
        "inicio"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"reglasAplicadas", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "reglas", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "Comprobamos", " ", "si", " ", "la", " ", "regla", " ", "se", " ", 
           "puede", " ", "aplicar"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"ReglaAplicable", "[", 
             RowBox[{"membrana", ",", 
              RowBox[{"reglas", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
