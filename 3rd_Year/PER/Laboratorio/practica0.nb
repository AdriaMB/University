Cell[CellGroupData[{

Cell["Estructuras de Control", "Subsection",
 CellChangeTimes->{{3.55228358147244*^9, 
  3.552283585601412*^9}},ExpressionUUID->"648101e1-7725-441a-9621-\
f0dba2184d35"],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " permite la evaluaci\[OAcute]n y ejecuci\[OAcute]n de estructuras de \
control de forma individual, esto es, sin necesidad de incorporarlas a una \
determinada funci\[OAcute]n. Utilizando de forma conveniente esta caracter\
\[IAcute]stica, es f\[AAcute]cil desarrollar y comprobar las distintas partes \
de un programa y, posteriormente, fusionar todas ellas para construir una \
funci\[OAcute]n."
}], "Text",ExpressionUUID->"b28d714f-a96b-48b2-be5b-bd6c2db83ad1"],

Cell["\<\
Al igual que con los operadores l\[OAcute]gicos, es importante tener presente \
la sintaxis de las estructuras de control para evitar errores.\
\>", "Text",
 CellChangeTimes->{{3.556431053176716*^9, 3.556431055763055*^9}, {
  3.55643112769836*^9, 
  3.556431168331245*^9}},ExpressionUUID->"211aea05-9a42-49a7-81b5-\
f69286854012"],

Cell[" Aspectos generales a tener en cuenta:", "Text",ExpressionUUID->"5c8f9b9b-019c-47e4-a3ef-ffca3044108b"],

Cell[TextData[{
 "Como en todo m\[OAcute]dulo predefinido en ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ", no importa de que estructura de control estemos hablando, ",
 StyleBox["la primera letra de la palabra reservada es may\[UAcute]scula",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"87f8fa3d-8e54-4619-a9a2-7699bf44e8b9"],

Cell[TextData[{
 "Toda instrucci\[OAcute]n relacionada con la instrucci\[OAcute]n \
est\[AAcute] encerrada entre ",
 StyleBox["corchetes",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"f96616cc-5fa5-4aa6-9864-6d1a655aa78f"],

Cell[TextData[{
 "Si hay m\[AAcute]s de una instrucci\[OAcute]n a ejecutar, estas se separan \
por ",
 StyleBox["punto y coma",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"9fd958fd-f2ff-4d8a-b227-eb01868a9c7d"],

Cell[TextData[{
 "Como en toda instrucci\[OAcute]n en ",
 StyleBox["Mathematica,",
  FontSlant->"Italic"],
 " hay que separar la \[OpenCurlyDoubleQuote]instrucci\[OAcute]n de control\
\[CloseCurlyDoubleQuote] de la siguiente instrucci\[OAcute]n con ",
 StyleBox["punto y coma",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"2549f4b6-40e1-4e7f-96ba-3e5b888ebe38"],

Cell[CellGroupData[{

Cell["Selecci\[OAcute]n condicional", "Subsubsection",
 CellChangeTimes->{{3.556431190786886*^9, 3.5564311951514378`*^9}, {
  3.5564312410633097`*^9, 
  3.5564312430209312`*^9}},ExpressionUUID->"3720131f-aaa7-4e98-8a75-\
9a860c53de7e"],

Cell["\<\
La estructura de selecci\[OAcute]n sigue el mismo esquema de todo lenguaje, \
siendo importante tener presente:\
\>", "Text",
 CellChangeTimes->{{3.5564312778732967`*^9, 
  3.55643131667542*^9}},ExpressionUUID->"6bb6e4cf-b235-4564-bb7b-\
df8e65b131a9"],

Cell[TextData[{
 StyleBox["Los tres bloques de la selecci\[OAcute]n",
  FontWeight->"Bold"],
 " (condici\[OAcute]n, conjunto de instrucciones a ejecutar si la condici\
\[OAcute]n es cierta y conjunto de instrucciones a ejecutar si la condici\
\[OAcute]n es falsa) ",
 StyleBox["est\[AAcute]n separados por comas",
  FontWeight->"Bold"]
}], "Item",
 CellChangeTimes->{{3.556431377920083*^9, 3.556431463210498*^9}, {
  3.5564314988922777`*^9, 
  3.556431520402521*^9}},ExpressionUUID->"3d0c83db-2f13-4841-aaa8-\
dc49837ee7ad"],

Cell[CellGroupData[{

Cell["\<\
El conjunto de instrucciones a ejecutar si la condici\[OAcute]n es falsa es \
opcional\
\>", "Item",
 CellChangeTimes->{{3.556431504381515*^9, 3.5564315286256847`*^9}, {
  3.556431651262126*^9, 
  3.5564316512660313`*^9}},ExpressionUUID->"ff673c21-7c18-4913-8d59-\
46bd41f8125b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"clave", "=", "23"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"clave", " ", ">", "0"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", "\"\<menor\>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"clave", "=", "0"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"clave", " ", "=", " ", 
       RowBox[{"clave", " ", "*", " ", "100"}]}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ";"}], 
  RowBox[{"(*", " ", "if", " ", "*)"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{
  3.5564311974346743`*^9, {3.556431246116292*^9, 3.556431268277771*^9}, {
   3.556431536525125*^9, 3.556431586205378*^9}, {3.556431728125194*^9, 
   3.556431773327381*^9}},ExpressionUUID->"694e02a6-e4e0-4cdf-a83d-\
a8cd1a5e2b57"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"clave", "=", "23"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"clave", " ", ">", "0"}], ",", "\[IndentingNewLine]", 
     RowBox[{"clave", "=", "0"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
  RowBox[{"(*", " ", "if", " ", "*)"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{
  3.5564311974346743`*^9, {3.556431246116292*^9, 3.556431268277771*^9}, {
   3.556431536525125*^9, 3.556431586205378*^9}, {3.556431728125194*^9, 
   3.5564317898598223`*^9}},ExpressionUUID->"bdd6c2b0-e65f-4156-97a0-\
3be7082da949"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["\[AliasDelimiter]Iteraci\[OAcute]n", "Subsubsection",
 CellChangeTimes->{{3.556431190786886*^9, 3.556431211508803*^9}, 
   3.979738397864038*^9},ExpressionUUID->"eb7d32dd-9246-4164-bdbd-\
172e165aeaf0"],

Cell["Nos centraremos en el uso de dos tipos de bucle: ", "Text",ExpressionUUID->"42c3503a-cb46-43c3-ae3b-e4b0e94ede63"],

Cell["Bucle While", "Text",
 FontWeight->"Bold",ExpressionUUID->"dc33e36b-0817-4975-9708-9cdcf07a7171"],

Cell[TextData[{
 " Es importante tener presente que ",
 StyleBox["los dos bloques de la iteraci\[OAcute]n",
  FontWeight->"Bold"],
 " (condici\[OAcute]n y conjunto de instrucciones a ejecutar) ",
 StyleBox["est\[AAcute]n separados por comas",
  FontWeight->"Bold"]
}], "Text",ExpressionUUID->"eaf46086-b1c1-4337-8eec-83a782d200aa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"clave", "=", "False"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"i", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"!", "clave"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"i", "++"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", ">", "10"}], ",", 
        RowBox[{"clave", "=", "True"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "i", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}],
    ";"}], 
  RowBox[{"(*", " ", "while", " ", "*)"}]}], "\[IndentingNewLine]"}], "Input",\
ExpressionUUID->"72c76f43-988d-46d5-b533-ef3278910d6b"],

Cell["Bucle For", "Text",
 FontWeight->"Bold",ExpressionUUID->"6c676e69-189f-4160-9dd2-876a4b36df39"],

Cell[TextData[{
 "Al igual que en el bucle while, ",
 StyleBox["los cuatro bloques de la iteraci\[OAcute]n",
  FontWeight->"Bold"],
 " (inicializaci\[OAcute]n, condici\[OAcute]n, paso y conjunto de \
instrucciones a ejecutar) ",
 StyleBox["est\[AAcute]n separados por comas",
  FontWeight->"Bold"]
}], "Text",
 CellChangeTimes->{{3.556515055023978*^9, 
  3.55651505773109*^9}},ExpressionUUID->"ce1a257e-1248-4e14-8d08-\
bffb7f51ca2e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "0"}], ",", 
     RowBox[{"i", "\[LessEqual]", "10"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<valor de i:\>\"", ",", "i"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ";"}], 
  RowBox[{"(*", " ", "for", " ", "*)"}]}]], "Input",ExpressionUUID->"6162daa6-\
a3bc-4401-b49b-4dedecaabadf"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["M\[OAcute]dulos", "Subsection",
 CellChangeTimes->{{3.552283592013674*^9, 
  3.552283607639298*^9}},ExpressionUUID->"12a88b27-dc3f-4a88-8ed3-\
11870ebda31c"],

Cell[TextData[{
 "Mathematica lleva incorporado un lenguaje de programaci\[OAcute]n propio \
que permite incorporar funciones para realizar tareas espec\[IAcute]ficas al \
mismo nivel que las funciones predefinidas.  Para resolver los ejercicios de \
las pr\[AAcute]cticas nos centraremos en el dise\[NTilde]o de ",
 StyleBox["m\[OAcute]dulos",
  FontWeight->"Bold"],
 ". "
}], "Text",ExpressionUUID->"5ae25f30-d479-4585-b9cd-46a968d2d666"],

Cell[TextData[{
 "El objetivo de las pr\[AAcute]cticas es implementar algoritmos relacionados \
con la Teor\[IAcute]a de Lenguajes y su aplicaci\[OAcute]n al problema del ",
 StyleBox["string matching",
  FontSlant->"Italic"],
 ", dejando de lado otros aspectos, por lo que ",
 StyleBox["asumiremos que las llamadas a los m\[OAcute]dulos son correctas",
  FontWeight->"Bold"],
 ", con el n\[UAcute]mero apropiado de par\[AAcute]metros y del tipo correcto."
}], "Text",ExpressionUUID->"d981581d-3dbd-4173-815a-65807e913ba4"],

Cell["\<\
El concepto de m\[OAcute]dulo es totalmente parecido al de procedimiento en \
otros lenguajes de programaci\[OAcute]n. Su esquema gen\[EAcute]rico es:\
\>", "Text",ExpressionUUID->"bb0141a3-d299-4ba6-a9ac-84405f93d6c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"NombreDelModulo", "[", "ListadeParametros", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "listadevariableslocales", "}"}], ",", "\[IndentingNewLine]",
     "       ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "instruccion", ";", "\[IndentingNewLine]", "instruccion", ";"}], 
       "\[IndentingNewLine]", "..."}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", "valordesalida", "]"}]}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "fin", " ", "de", " ", "la", " ", "definici\[OAcute]n", " ", "del", " ", 
    "modulo"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.5564321317527018`*^9, 3.556432216748378*^9}, {
  3.556432541797337*^9, 3.556432553216014*^9}, {3.587281043186861*^9, 
  3.5872810498012867`*^9}},ExpressionUUID->"dc5eb3c1-4d02-46ce-a0f8-\
a5dfa492d855"],

Cell["\<\
Para evitar errores dif\[IAcute]ciles de depurar es importante tener presente:\
\>", "Text",
 CellChangeTimes->{{3.5564312778732967`*^9, 3.55643131667542*^9}, {
  3.5564318112518673`*^9, 3.556431893082465*^9}, {3.5564323862852697`*^9, 
  3.556432397039398*^9}},ExpressionUUID->"c122d766-1cd0-4e3f-b77c-\
6328d87a4735"],

Cell[TextData[{
 "Las versiones actuales de ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " sangran el c\[OAcute]digo y lo colorean en funci\[OAcute]n de la sintaxis. \
Un sangrado o coloreado no esperado, puede indicar la presencia de un error. \
"
}], "Item",
 CellChangeTimes->{{3.556431323019968*^9, 3.556431347154615*^9}, {
  3.5564319052665777`*^9, 3.5564319148398247`*^9}, {3.5564324020010777`*^9, 
  3.556432488740494*^9}},ExpressionUUID->"a4eb277c-9a0d-4c37-9198-\
853a8a15766a"],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " no permite la modificaci\[OAcute]n de los par\[AAcute]metros"
}], "Item",
 CellChangeTimes->{{3.556431349244019*^9, 3.556431374424849*^9}, {
  3.5564315963285637`*^9, 3.556431596331321*^9}, {3.556431919869282*^9, 
  3.5564319237275953`*^9}, {3.5564324990097857`*^9, 
  3.556432534897833*^9}},ExpressionUUID->"e3ce0cd2-9ddd-4f27-bc20-\
c25fd43b6148"],

Cell[TextData[{
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " permite indicar el tipo de cada par\[AAcute]metro. Sin embargo esto es \
opcional."
}], "Item",
 CellChangeTimes->{{3.556431377920083*^9, 3.556431463210498*^9}, {
  3.5564314988922777`*^9, 3.556431520402521*^9}, {3.556431936837392*^9, 
  3.556431950243979*^9}, {3.55643256207795*^9, 
  3.556432632097774*^9}},ExpressionUUID->"896376a9-da9c-497f-8f0e-\
acfb2b0ce301"],

Cell[CellGroupData[{

Cell[TextData[{
 "El gui\[OAcute]n de subrayado tiene una sem\[AAcute]ntica asociada en ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 " y no debe usarse como parte de un identificador"
}], "Item",
 CellChangeTimes->{{3.5564315968797283`*^9, 3.556431639854207*^9}, 
   3.5564319601216927`*^9, {3.556432643382518*^9, 
   3.5564327092852592`*^9}},ExpressionUUID->"cb3243b8-d81f-48e2-a493-\
9984a08041ed"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Potencia", "[", 
   RowBox[{"base_", ",", "exponente_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"i", ",", "resultado"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"resultado", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", "exponente"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"resultado", "=", 
         RowBox[{"resultado", "*", "base"}]}], ";"}]}], "\[IndentingNewLine]",
       "]"}], ";", 
     RowBox[{"(*", " ", "for", " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "resultado", "]"}], ";"}]}], 
   "\[IndentingNewLine]", "]"}], 
  RowBox[{"(*", " ", "Potencia", " ", "*)"}]}]], "Input",ExpressionUUID->\
"185d713a-cd70-41d2-81f3-3ed422e88688"],

Cell[CellGroupData[{

Cell["\<\
Una vez definido y evaluado un m\[OAcute]dulo, pueden incluirse llamadas a \
\[EAcute]l en otros m\[OAcute]dulos o bien ejecutarse de forma aislada\
\>", "ItemParagraph",
 CellChangeTimes->{{3.556515296197694*^9, 
  3.556515388966207*^9}},ExpressionUUID->"44b508d2-d07c-429d-a115-\
e5f6e2b8d3f5"],

