Cell[CellGroupData[{

Cell[TextData[{
 "Cases[lista,patr\[OAcute]n]: Devuelve una lista con los elementos del \
primer par\[AAcute]metro que concuerdan con patr\[OAcute]n indicado en el \
segundo elemento. El patr\[OAcute]n permite fijar la longitud o estructura de \
los elementos que interesa seleccionar y puede contener el s\[IAcute]mbolo \"",
 StyleBox["_",
  FontWeight->"Bold"],
 "\", que hace la funci\[OAcute]n de comod\[IAcute]n."
}], "Item",
 CellChangeTimes->{{3.552290784732951*^9, 
  3.5522909107904387`*^9}},ExpressionUUID->"c857a10a-47c0-414c-bf15-\
a099fa95abdf"],

