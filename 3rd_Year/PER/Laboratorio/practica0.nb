 RowBox[{
  RowBox[{"lista", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", "a", ",", "b"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", ",", "b", ",", "a"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", ",", "b"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"a", ",", "b"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "elementos", " ", "de", " ", "lista", " ", "que", " ", "son", " ", 
     "listas", " ", "de", " ", "longitud", " ", "tres"}], "..."}], " ", 
   "*)"}], 
  RowBox[{"Cases", "[", 
   RowBox[{"lista", ",", 
    RowBox[{"{", 
     RowBox[{"_", ",", "_", ",", "_"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "elementos", " ", "que", " ", "son", " ", "listas", " ", "de", " ", 
     "longitud", " ", "dos", " ", "que", " ", "empiezan", " ", "por", " ", 
     "a"}], "..."}], " ", "*)"}]}], "\[IndentingNewLine]", 
